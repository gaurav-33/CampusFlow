# ── AWS Configuration ──────────────────────────────────────────────────────────
AWS_REGION=ap-south-1

# ── DynamoDB ───────────────────────────────────────────────────────────────────
DYNAMODB_TABLE_NAME=CampusFlowData

# ── SQS ───────────────────────────────────────────────────────────────────────
SQS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/<ACCOUNT_ID>/BedrockProcessingQueue

# ── Bedrock ────────────────────────────────────────────────────────────────────
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_REGION=ap-south-1

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_AT_LEAST_64_CHARS
JWT_EXPIRES_IN=24h

# ── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

# ── AI Providers ───────────────────────────────────────────────────────────────
AI_PROVIDER=groq                     # Options: groq, bedrock
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Notifications & SNS ────────────────────────────────────────────────────────
SNS_TOPIC_ARN=arn:aws:sns:ap-south-1:<ACCOUNT_ID>:CampusFlowNudges-production

# ── S3 Buckets ─────────────────────────────────────────────────────────────────
UPLOADS_BUCKET=campusflow-uploads-<ACCOUNT_ID>-production
EMAIL_BUCKET=campusflow-uploads-<ACCOUNT_ID>-production

# ── Email Sync ─────────────────────────────────────────────────────────────────
SYNC_EMAIL_DOMAIN=sync.campusflow.com
