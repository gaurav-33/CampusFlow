{
  "expo": {
    "name": "CampusFlow",
    "slug": "campusflow",
    "scheme": "campusflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#101030",
      "imageWidth": 578
    },
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.campusflow.app",
      "supportsTablet": true
    },
    "android": {
      "package": "com.campusflow.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#101030"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-share-intent",
        {
          "ios": {
            "bundleId": "com.campusflow.app.ShareExtension"
          }
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "f4a35a0a-7771-40c0-93b7-844d26bbfbc4"
      }
    }
  }
}
